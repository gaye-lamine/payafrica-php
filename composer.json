{
  "name": "payafrica/core-php",
  "description": "Unified mobile-money payment SDK core for PHP.",
  "license": "MIT",
  "type": "library",
  "require": {
    "php": ">=8.1",
    "psr/http-client": "^1.0",
    "psr/http-message": "^1.0 || ^2.0",
    "guzzlehttp/psr7": "^2.0"
  },
  "require-dev": {
    "guzzlehttp/guzzle": "^7.0",
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "PayAfrica\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PayAfrica\\Sdk\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
